# =============================================================================
# Fluctum Starter — Environment Variables Template
# Copy this file to backend/.env (and storefront/.env.local for storefront vars)
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fluctum

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# CORS — set to the URLs where your storefront and admin panel are served
# -----------------------------------------------------------------------------
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

# -----------------------------------------------------------------------------
# Secrets — replace with strong random values in production
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
COOKIE_SECRET=your_cookie_secret_here

# -----------------------------------------------------------------------------
# Storefront (used in storefront/.env.local with NEXT_PUBLIC_ prefix)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_DEFAULT_REGION=us

# -----------------------------------------------------------------------------
# Medusa Cloud — S3-compatible file storage (set when deploying to Medusa Cloud)
# -----------------------------------------------------------------------------
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
